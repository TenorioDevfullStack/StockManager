# Supabase
# Encontre esses valores em:
# Supabase Dashboard > Project Settings > API
SUPABASE_URL=https://seu-project-ref.supabase.co
SUPABASE_ANON_KEY=sua-chave-anon-public

# Bot API / Supabase Edge Function
# Use estes valores apenas como secrets da Edge Function ou em ambiente local.
# Nunca exponha SUPABASE_SERVICE_ROLE_KEY no frontend.
SUPABASE_SERVICE_ROLE_KEY=sua-chave-service-role
BOT_API_KEY=gere-uma-chave-longa-para-o-bot
# Usuario que sera registrado como autor das movimentacoes feitas pelo bot.
BOT_USER_ID=uuid-do-usuario-dono-do-estoque
# Organizacao (equipe) cujo estoque o bot pode acessar.
BOT_ORG_ID=uuid-da-organizacao
